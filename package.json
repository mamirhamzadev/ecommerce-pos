{
  "name": "pos-mushtaq",
  "version": "1.0.1",
  "description": "Electron POS shell with SQLite auth (admin / user)",
  "repository": {
    "type": "git",
    "url": "https://github.com/mamirhamzadev/ecommerce-pos.git",
    "owner": "mamirhamzadev",
    "repo": "ecommerce-pos"
  },
  "main": "main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "vite build",
    "prestart": "npm run build",
    "start": "electron .",
    "dist": "npm run build && electron-builder --config electron-builder.config.cjs",
    "dist:publish": "npm run build && electron-builder --config electron-builder.config.cjs --publish always",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.3.0",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@reduxjs/toolkit": "^2.11.2",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.6.0",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "electron-updater": "^6.8.3",
    "nodemailer": "^8.0.7",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.15.0",
    "react-toastify": "^11.1.0"
  }
}
