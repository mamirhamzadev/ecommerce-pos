{
  "name": "pos-mushtaq",
  "version": "1.0.0",
  "description": "Electron POS shell with SQLite auth (admin / user)",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "vite build",
    "prestart": "npm run build",
    "start": "electron .",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.6.0",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "nodemailer": "^8.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
