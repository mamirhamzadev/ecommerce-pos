<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New admin verification</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f4f5;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#f4f4f5;">
    <tr>
      <td align="center" style="padding:32px 16px;">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:560px;background-color:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 4px 24px rgba(15,23,42,0.08);">
          <tr>
            <td style="padding:28px 32px 8px 32px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
              <p style="margin:0 0 8px 0;font-size:13px;font-weight:600;color:#6366f1;letter-spacing:0.02em;text-transform:uppercase;"><%= appName %></p>
              <h1 style="margin:0 0 16px 0;font-size:22px;line-height:1.3;color:#0f172a;">Verify new admin account</h1>
              <p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#334155;">Hello <%= name %>,</p>
              <p style="margin:0 0 20px 0;font-size:15px;line-height:1.6;color:#334155;">Someone signed in as <strong>@<%= username %></strong> is creating a new <strong>admin</strong> user in the app. Enter this code in the “New user” form to confirm:</p>
            </td>
          </tr>
          <tr>
            <td align="center" style="padding:0 32px 24px 32px;">
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="background-color:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;">
                <tr>
                  <td style="padding:16px 28px;font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,'Liberation Mono','Courier New',monospace;font-size:26px;font-weight:700;letter-spacing:0.18em;color:#0f172a;">
                    <%= code %>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td style="padding:0 32px 28px 32px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
              <p style="margin:0 0 12px 0;font-size:14px;line-height:1.6;color:#64748b;">This code expires in <strong style="color:#334155;">15 minutes</strong>.</p>
              <p style="margin:0 0 20px 0;font-size:14px;line-height:1.6;color:#64748b;">If you did not start this, change your password and review user accounts.</p>
              <p style="margin:0;font-size:14px;line-height:1.6;color:#334155;">Thanks,<br><strong><%= appName %></strong></p>
            </td>
          </tr>
          <tr>
            <td style="padding:16px 32px 24px 32px;border-top:1px solid #f1f5f9;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
              <p style="margin:0;font-size:12px;line-height:1.5;color:#94a3b8;">Do not share this code. Only enter it in your own app session.</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
