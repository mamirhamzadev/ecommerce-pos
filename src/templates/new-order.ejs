<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New order</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f4f5;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#f4f4f5;">
    <tr>
      <td align="center" style="padding:28px 16px;">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:560px;background-color:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 4px 24px rgba(15,23,42,0.08);">
          <tr>
            <td style="padding:24px 28px 8px 28px;">
              <p style="margin:0 0 8px 0;font-size:12px;font-weight:600;color:#6366f1;letter-spacing:0.06em;text-transform:uppercase;"><%= appName %></p>
              <h1 style="margin:0 0 12px 0;font-size:20px;line-height:1.3;color:#0f172a;">New order placed</h1>
              <p style="margin:0 0 20px 0;font-size:14px;line-height:1.55;color:#334155;">
                <strong><%= placedByName %></strong> (<code style="background:#f1f5f9;padding:2px 6px;border-radius:4px;"><%= placedByUsername %></code>) created order
                <strong style="color:#0f172a;"><%= order.order_number %></strong>.
              </p>
            </td>
          </tr>
          <tr>
            <td style="padding:0 28px 16px 28px;">
              <p style="margin:0 0 10px 0;font-size:13px;font-weight:600;color:#0f172a;">Line items</p>
              <table width="100%" cellspacing="0" cellpadding="0" border="0" style="font-size:13px;color:#334155;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;">
                <tr style="background:#f8fafc;">
                  <td style="padding:8px 12px;font-weight:600;">Product</td>
                  <td style="padding:8px 12px;font-weight:600;text-align:right;">Qty</td>
                  <td style="padding:8px 12px;font-weight:600;text-align:right;">Line total</td>
                </tr>
                <% const items = Array.isArray(order.items) ? order.items : []; %>
                <% items.forEach(function (it) { %>
                <tr>
                  <td style="padding:8px 12px;border-top:1px solid #e2e8f0;"><%= it.product_name %></td>
                  <td style="padding:8px 12px;border-top:1px solid #e2e8f0;text-align:right;"><%= it.qty %></td>
                  <td style="padding:8px 12px;border-top:1px solid #e2e8f0;text-align:right;">PKR <%= Number(it.line_total).toFixed(2) %></td>
                </tr>
                <% }); %>
                <% if (items.length === 0) { %>
                <tr><td colspan="3" style="padding:10px 12px;border-top:1px solid #e2e8f0;color:#64748b;">No line rows (legacy order).</td></tr>
                <% } %>
                <tr style="background:#f8fafc;">
                  <td colspan="2" style="padding:8px 12px;border-top:1px solid #e2e8f0;font-weight:600;">Order total</td>
                  <td style="padding:8px 12px;border-top:1px solid #e2e8f0;text-align:right;font-weight:600;">PKR <%= Number(order.total).toFixed(2) %></td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td style="padding:0 28px 16px 28px;">
              <table width="100%" cellspacing="0" cellpadding="0" border="0" style="font-size:14px;color:#334155;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;">
                <tr style="background:#f8fafc;">
                  <td style="padding:10px 14px;font-weight:600;width:38%;">Field</td>
                  <td style="padding:10px 14px;font-weight:600;">Value</td>
                </tr>
                <tr><td style="padding:8px 14px;border-top:1px solid #e2e8f0;">Customer</td><td style="padding:8px 14px;border-top:1px solid #e2e8f0;"><%= order.customer_name %></td></tr>
                <tr><td style="padding:8px 14px;border-top:1px solid #e2e8f0;">Contact</td><td style="padding:8px 14px;border-top:1px solid #e2e8f0;"><%= order.customer_contact || '—' %></td></tr>
                <tr><td style="padding:8px 14px;border-top:1px solid #e2e8f0;">City</td><td style="padding:8px 14px;border-top:1px solid #e2e8f0;"><%= order.customer_city || '—' %></td></tr>
                <tr><td style="padding:8px 14px;border-top:1px solid #e2e8f0;">Address</td><td style="padding:8px 14px;border-top:1px solid #e2e8f0;"><%= order.customer_address || '—' %></td></tr>
                <tr><td style="padding:8px 14px;border-top:1px solid #e2e8f0;">Note</td><td style="padding:8px 14px;border-top:1px solid #e2e8f0;"><%= order.note || '—' %></td></tr>
                <tr><td style="padding:8px 14px;border-top:1px solid #e2e8f0;">Status</td><td style="padding:8px 14px;border-top:1px solid #e2e8f0;text-transform:capitalize;"><%= order.status %></td></tr>
                <tr><td style="padding:8px 14px;border-top:1px solid #e2e8f0;">Created</td><td style="padding:8px 14px;border-top:1px solid #e2e8f0;"><%= order.created_at %></td></tr>
              </table>
            </td>
          </tr>
          <tr>
            <td style="padding:12px 28px 24px 28px;border-top:1px solid #f1f5f9;">
              <p style="margin:0;font-size:12px;line-height:1.5;color:#94a3b8;">This is an automated message from <%= appName %>.</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
